generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountStatus {
  available
  sold
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_SUBMITTED
  WAITING_FOR_ACCOUNT
  FULFILLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewSource {
  ADMIN_PANEL
  TELEGRAM
}

enum PaymentAuditAction {
  SUBMITTED
  RESUBMITTED
  TELEGRAM_SENT
  TELEGRAM_SEND_FAILED
  APPROVED
  REJECTED
}

enum PaymentAuditActor {
  USER
  ADMIN
  TELEGRAM
  SYSTEM
}

enum NotificationType {
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  ACCOUNT_READY
  ACCOUNT_DELAYED
}

enum ConversationType {
  GENERAL_SUPPORT
  ORDER_SUPPORT
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?        @unique
  passwordHash  String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  notifications Notification[]
  conversations Conversation[] @relation("UserConversations")
  messages      Message[]      @relation("UserMessages")
  passwordResetTokens PasswordResetToken[]

  @@index([role, createdAt])
}

model Plan {
  id           String    @id @default(cuid())
  name         String
  price        Decimal   @db.Decimal(12, 0)
  durationDays Int       @default(30)
  maxUsers     Int?
  createdAt    DateTime  @default(now())
  accounts     Account[]
  orders       Order[]

  @@index([createdAt])
}

model Account {
  id        String        @id @default(cuid())
  config    String        @db.Text
  status    AccountStatus @default(available)
  planId    String
  createdAt DateTime      @default(now())
  plan      Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  order     Order?

  @@index([planId, status, createdAt])
}

model Order {
  id            String         @id @default(cuid())
  userId        String
  planId        String
  accountId     String?        @unique
  amount        Decimal        @db.Decimal(12, 0)
  status        OrderStatus    @default(PENDING_PAYMENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fulfilledAt   DateTime?
  expiresAt     DateTime?
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  payment       Payment?
  notifications Notification[]
  conversation  Conversation?

  @@index([userId, createdAt])
  @@index([planId, status, createdAt])
}

model Payment {
  id                String            @id @default(cuid())
  orderId           String            @unique
  amount            Decimal           @db.Decimal(12, 0)
  trackingCode      String
  cardLast4         String
  receiptUrl        String
  receiptStoragePath String?
  status            PaymentStatus @default(PENDING)
  reviewSource      ReviewSource?
  reviewNote        String?
  submittedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  telegramMessageId String?
  telegramSentAt    DateTime?
  telegramError     String?
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  auditLogs         PaymentAuditLog[]

  @@index([status, submittedAt])
}

model PaymentAuditLog {
  id        String            @id @default(cuid())
  paymentId String
  action    PaymentAuditAction
  actorType PaymentAuditActor
  actorId   String?
  message   String
  metadata  Json?
  createdAt DateTime          @default(now())
  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  type      NotificationType
  title     String
  message   String
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId, createdAt])
}

model Conversation {
  id                 String             @id @default(cuid())
  conversationKey    String             @unique
  type               ConversationType
  status             ConversationStatus @default(OPEN)
  userId             String
  orderId            String?            @unique
  title              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadByUser       Int                @default(0)
  unreadByAdmin      Int                @default(0)
  closedAt           DateTime?
  user               User               @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  order              Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages           Message[]

  @@index([userId, updatedAt])
  @@index([status, lastMessageAt])
  @@index([type, updatedAt])
}

model Message {
  id                 String      @id @default(cuid())
  conversationId     String
  senderId           String
  senderRole         UserRole
  type               MessageType @default(TEXT)
  body               String      @db.Text
  attachmentUrl      String?
  attachmentName     String?
  attachmentMimeType String?
  attachmentSize     Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  readAt             DateTime?
  editedAt           DateTime?
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             User         @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}
