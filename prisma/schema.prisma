generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountStatus {
  available
  sold
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_SUBMITTED
  WAITING_FOR_ACCOUNT
  FULFILLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewSource {
  ADMIN_PANEL
  TELEGRAM
}

enum PaymentAuditAction {
  SUBMITTED
  RESUBMITTED
  TELEGRAM_SENT
  TELEGRAM_SEND_FAILED
  APPROVED
  REJECTED
}

enum PaymentAuditActor {
  USER
  ADMIN
  TELEGRAM
  SYSTEM
}

enum NotificationType {
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  ACCOUNT_READY
  ACCOUNT_DELAYED
}

enum ConversationType {
  GENERAL_SUPPORT
  ORDER_SUPPORT
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  ADJUST
}

enum CouponKind {
  PERCENT
  FIXED
}

enum GiftCardStatus {
  ACTIVE
  DISABLED
  EXPIRED
}

enum ReferralRewardTrigger {
  PAYMENT_APPROVED
}

enum ReferralAttributionStatus {
  PENDING
  REWARDED
  REJECTED
}

enum WalletTopUpStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?        @unique
  passwordHash  String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  notifications Notification[]
  conversations Conversation[] @relation("UserConversations")
  messages      Message[]      @relation("UserMessages")
  passwordResetTokens PasswordResetToken[]
  wallet        Wallet?
  createdCoupons      Coupon[]            @relation("CouponCreatedByAdmin")
  createdGiftCards    GiftCard[]          @relation("GiftCardCreatedByAdmin")
  createdReferralCampaigns ReferralCampaign[] @relation("ReferralCampaignCreatedByAdmin")
  couponRedemptions   CouponRedemption[]
  giftCardRedemptions GiftCardRedemption[]
  ownedReferralCodes  ReferralCode[]
  referralAttributions ReferralAttribution[]
  walletTopUps WalletTopUp[] @relation("WalletTopUpUser")
  reviewedWalletTopUps WalletTopUp[] @relation("WalletTopUpReviewedByAdmin")

  @@index([role, createdAt])
}

model Plan {
  id           String    @id @default(cuid())
  name         String
  price        Decimal   @db.Decimal(12, 0)
  durationDays Int       @default(30)
  maxUsers     Int?
  createdAt    DateTime  @default(now())
  accounts     Account[]
  orders       Order[]
  couponAllowedPlans CouponAllowedPlan[]

  @@index([createdAt])
}

model Account {
  id        String        @id @default(cuid())
  config    String        @db.Text
  status    AccountStatus @default(available)
  planId    String
  createdAt DateTime      @default(now())
  plan      Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  order     Order?

  @@index([planId, status, createdAt])
}

model Order {
  id            String         @id @default(cuid())
  userId        String
  planId        String
  accountId     String?        @unique
  subtotalAmount       Decimal        @db.Decimal(12, 0)
  discountAmount       Decimal        @db.Decimal(12, 0) @default(0)
  walletAppliedAmount  Decimal        @db.Decimal(12, 0) @default(0)
  giftCardAppliedAmount Decimal       @db.Decimal(12, 0) @default(0)
  amount        Decimal        @db.Decimal(12, 0)
  status        OrderStatus    @default(PENDING_PAYMENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fulfilledAt   DateTime?
  expiresAt     DateTime?
  couponId      String?
  giftCardId    String?
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Restrict)
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  payment       Payment?
  notifications Notification[]
  conversation  Conversation?
  coupon        Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  giftCard      GiftCard?      @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  couponRedemption   CouponRedemption?
  giftCardRedemptions GiftCardRedemption[]
  referralAttributionFirstOrder ReferralAttribution? @relation("ReferralAttributionFirstOrder")

  @@index([userId, createdAt])
  @@index([planId, status, createdAt])
  @@index([couponId, createdAt])
  @@index([giftCardId, createdAt])
}

model Payment {
  id                String            @id @default(cuid())
  orderId           String            @unique
  amount            Decimal           @db.Decimal(12, 0)
  trackingCode      String
  cardLast4         String
  receiptUrl        String
  receiptStoragePath String?
  status            PaymentStatus @default(PENDING)
  reviewSource      ReviewSource?
  reviewNote        String?
  submittedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  telegramMessageId String?
  telegramSentAt    DateTime?
  telegramError     String?
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  auditLogs         PaymentAuditLog[]

  @@index([status, submittedAt])
}

model PaymentAuditLog {
  id        String            @id @default(cuid())
  paymentId String
  action    PaymentAuditAction
  actorType PaymentAuditActor
  actorId   String?
  message   String
  metadata  Json?
  createdAt DateTime          @default(now())
  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  type      NotificationType
  title     String
  message   String
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId, createdAt])
}

model Conversation {
  id                 String             @id @default(cuid())
  conversationKey    String             @unique
  type               ConversationType
  status             ConversationStatus @default(OPEN)
  userId             String
  orderId            String?            @unique
  title              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadByUser       Int                @default(0)
  unreadByAdmin      Int                @default(0)
  closedAt           DateTime?
  user               User               @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  order              Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages           Message[]

  @@index([userId, updatedAt])
  @@index([status, lastMessageAt])
  @@index([type, updatedAt])
}

model Message {
  id                 String      @id @default(cuid())
  conversationId     String
  senderId           String
  senderRole         UserRole
  type               MessageType @default(TEXT)
  body               String      @db.Text
  attachmentUrl      String?
  attachmentName     String?
  attachmentMimeType String?
  attachmentSize     Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  readAt             DateTime?
  editedAt           DateTime?
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             User         @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @db.Decimal(12, 0) @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([createdAt])
}

model WalletTransaction {
  id        String                @id @default(cuid())
  walletId  String
  type      WalletTransactionType
  amount    Decimal               @db.Decimal(12, 0)
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime              @default(now())
  wallet    Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@index([refType, refId])
}

model WalletTopUp {
  id                 String           @id @default(cuid())
  userId             String
  amount             Decimal          @db.Decimal(12, 0)
  trackingCode       String
  cardLast4          String
  receiptUrl         String
  receiptStoragePath String?
  status             WalletTopUpStatus @default(PENDING)
  reviewNote         String?
  reviewedAt         DateTime?
  reviewedByAdminId  String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation("WalletTopUpUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedByAdmin    User?            @relation("WalletTopUpReviewedByAdmin", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  kind               CouponKind
  value              Decimal    @db.Decimal(12, 0)
  maxDiscountAmount  Decimal?   @db.Decimal(12, 0)
  minOrderAmount     Decimal?   @db.Decimal(12, 0)
  startsAt           DateTime?
  endsAt             DateTime?
  usageLimitTotal    Int?
  usageLimitPerUser  Int?
  isActive           Boolean    @default(true)
  createdByAdminId   String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  createdByAdmin     User?      @relation("CouponCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  redemptions        CouponRedemption[]
  allowedPlans       CouponAllowedPlan[]
  orders             Order[]

  @@index([isActive, createdAt])
  @@index([startsAt, endsAt])
}

model CouponAllowedPlan {
  id       String @id @default(cuid())
  couponId String
  planId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  plan     Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([couponId, planId])
  @@index([planId])
}

model CouponRedemption {
  id              String   @id @default(cuid())
  couponId        String
  userId          String
  orderId         String   @unique
  amountDiscounted Decimal @db.Decimal(12, 0)
  createdAt       DateTime @default(now())
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, createdAt])
  @@index([userId, createdAt])
}

model GiftCard {
  id               String         @id @default(cuid())
  code             String         @unique
  initialAmount    Decimal        @db.Decimal(12, 0)
  balance          Decimal        @db.Decimal(12, 0)
  startsAt         DateTime?
  endsAt           DateTime?
  status           GiftCardStatus @default(ACTIVE)
  createdByAdminId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdByAdmin   User?          @relation("GiftCardCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  redemptions      GiftCardRedemption[]
  orders           Order[]

  @@index([status, createdAt])
  @@index([startsAt, endsAt])
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String
  userId      String
  orderId     String
  amountUsed  Decimal  @db.Decimal(12, 0)
  createdAt   DateTime @default(now())
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([giftCardId, orderId])
  @@index([giftCardId, createdAt])
  @@index([userId, createdAt])
}

model ReferralCampaign {
  id               String               @id @default(cuid())
  name             String
  description      String?
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean              @default(true)
  rewardValue      Decimal              @db.Decimal(12, 0)
  rewardTrigger    ReferralRewardTrigger @default(PAYMENT_APPROVED)
  maxRewardsTotal  Int?
  maxRewardsPerReferrer Int?
  createdByAdminId String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  createdByAdmin   User?                @relation("ReferralCampaignCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  codes            ReferralCode[]

  @@index([isActive, createdAt])
  @@index([startsAt, endsAt])
}

model ReferralCode {
  id          String   @id @default(cuid())
  code        String   @unique
  campaignId  String
  ownerUserId String?
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  campaign    ReferralCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ownerUser   User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  attributions ReferralAttribution[]

  @@index([campaignId, createdAt])
  @@index([ownerUserId])
  @@index([isActive, createdAt])
}

model ReferralAttribution {
  id             String                    @id @default(cuid())
  referralCodeId String
  referredUserId String
  firstOrderId   String?                   @unique
  status         ReferralAttributionStatus @default(PENDING)
  createdAt      DateTime                  @default(now())
  rewardedAt     DateTime?
  referralCode   ReferralCode              @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUser   User                      @relation(fields: [referredUserId], references: [id], onDelete: Cascade)
  firstOrder     Order?                    @relation("ReferralAttributionFirstOrder", fields: [firstOrderId], references: [id], onDelete: SetNull)

  @@unique([referralCodeId, referredUserId])
  @@index([referredUserId, createdAt])
  @@index([status, createdAt])
}
