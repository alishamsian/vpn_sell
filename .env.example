DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.project-ref.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.project-ref.supabase.co:5432/postgres"
# اختیاری: اگر Prisma خطای connection pool timeout داد (پیش‌فرض pool در URL اضافه می‌شود: ۳۰ ثانیه)
# DATABASE_POOL_TIMEOUT=45
# DATABASE_CONNECT_TIMEOUT=25
# برای Supabase در پروداکشن معمولاً DATABASE_URL به pooler (پورت 6543) + ?pgbouncer=true و DIRECT_URL مستقیم است.
# لوگو: فایل `public/vpn-alish-logo.png` را جایگزین کن؛ اگر کش ماند، نام فایل را عوض کن و در `components/brand-logo.tsx` مسیر را به‌روز کن.
AUTH_SECRET="change-this-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_RECEIPT_BUCKET="payment-receipts"
SUPABASE_CHAT_BUCKET="chat-attachments"
